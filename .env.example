# Backend Environment Variables

# Database
POSTGRES_DB=easymeeting
POSTGRES_USER=easymeeting
POSTGRES_PASSWORD=easymeeting

# Redis
REDIS_URL=redis://redis:6379

# OAuth Configuration
OAUTH_CLIENT_ID=your-google-oauth-client-id
OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# Session Encryption
SESSION_ENCRYPTION_KEY=change-this-to-a-secure-random-32-character-string

# Email Configuration (SMTP)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# Application URL
APP_BASE_URL=http://localhost:3000

# Magic Link Configuration
MAGIC_LINK_EXPIRATION_MINUTES=15
